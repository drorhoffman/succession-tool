<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

:root{
  --bg:       #060B16;
  --bg2:      #0A1120;
  --card:     #0C1628;
  --card2:    #101F38;
  --border:   #162035;
  --border2:  #1E3050;
  --cyan:     #22D3EE;
  --cyan-d:   rgba(34,211,238,.12);
  --cyan-dd:  rgba(34,211,238,.06);
  --indigo:   #818CF8;
  --green:    #10B981;
  --green-d:  rgba(16,185,129,.12);
  --amber:    #F59E0B;
  --amber-d:  rgba(245,158,11,.12);
  --red:      #F87171;
  --red-d:    rgba(248,113,113,.12);
  --purple:   #A78BFA;
  --purple-d: rgba(167,139,250,.12);
  --t1:       #E2E8F0;
  --t2:       #4B6A9A;
  --t3:       #223050;
  --glow-c:   0 0 20px rgba(34,211,238,.15);
  --glow-s:   0 0 8px rgba(34,211,238,.2);
}

body{
  font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;
  background: var(--bg);
  background-image: radial-gradient(rgba(30,64,120,.2) 1px,transparent 1px);
  background-size: 28px 28px;
  color: var(--t1);
  min-height:100vh;
  direction:rtl;
  line-height:1.5;
}

/* ─ Screens ─ */
.screen{display:none!important;}
.screen.active{display:block!important;}
#welcome.active{display:flex!important;}

/* ════════════ WELCOME ════════════ */
#welcome{min-height:100vh;align-items:center;justify-content:center;}
.wcard{
  background:var(--card);
  border:1px solid var(--border2);
  border-radius:16px;
  padding:56px 48px;
  max-width:520px;width:92%;
  text-align:center;
  box-shadow:var(--glow-c),0 0 60px rgba(0,0,0,.5);
  position:relative;overflow:hidden;
}
.wcard::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--cyan),transparent);
}
.wlogo{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--cyan);margin-bottom:32px;opacity:.8;}
.wtitle{font-size:34px;font-weight:800;color:var(--t1);margin-bottom:10px;letter-spacing:-.5px;}
.wsub{font-size:15px;color:var(--t2);line-height:1.7;margin-bottom:40px;}
.wsteps{display:flex;justify-content:center;gap:14px;margin-bottom:44px;flex-wrap:wrap;}
.ws{display:flex;flex-direction:column;align-items:center;gap:8px;}
.wsico{
  width:48px;height:48px;
  background:var(--cyan-d);
  border:1px solid rgba(34,211,238,.2);
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;font-size:20px;
}
.wslbl{font-size:11px;color:var(--t2);font-weight:600;letter-spacing:.3px;}
.btn-start{
  background:linear-gradient(135deg,#0891B2,#0E7490);
  color:#fff;border:none;
  padding:16px 52px;border-radius:10px;
  font-size:16px;font-weight:700;cursor:pointer;
  box-shadow:0 0 24px rgba(34,211,238,.25);
  transition:all .2s;font-family:inherit;
  letter-spacing:.3px;
}
.btn-start:hover{box-shadow:0 0 36px rgba(34,211,238,.4);transform:translateY(-2px);}

/* ════════════ BUILDER ════════════ */
#builder{min-height:100vh;padding-bottom:60px;}

.bhead{
  background:var(--card);
  border-bottom:1px solid var(--border2);
  padding:16px 28px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100;
  box-shadow:0 4px 24px rgba(0,0,0,.4);
}
.bhead::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--cyan),transparent);opacity:.4;}
.bh-t{font-size:17px;font-weight:700;color:var(--cyan);}
.bh-s{font-size:11px;color:var(--t2);margin-top:2px;letter-spacing:.3px;}
.bh-a{display:flex;gap:10px;}

.btn-ghost{
  background:transparent;color:var(--t2);
  border:1px solid var(--border2);
  padding:8px 16px;border-radius:7px;
  font-size:13px;font-weight:600;cursor:pointer;
  transition:all .2s;font-family:inherit;
}
.btn-ghost:hover{border-color:var(--cyan);color:var(--cyan);}

.btn-gen{
  background:linear-gradient(135deg,#0891B2,#6D28D9);
  color:#fff;border:none;
  padding:9px 22px;border-radius:7px;
  font-size:13px;font-weight:700;cursor:pointer;
  transition:all .2s;font-family:inherit;
  box-shadow:0 0 16px rgba(34,211,238,.2);
}
.btn-gen:hover{box-shadow:0 0 24px rgba(34,211,238,.35);transform:translateY(-1px);}

.bbody{max-width:820px;margin:0 auto;padding:28px 20px;}

/* ─ Role card ─ */
.role-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:12px;
  margin-bottom:14px;
  overflow:hidden;
  transition:border-color .2s,box-shadow .2s;
  position:relative;
}
.role-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border2),transparent);}
.role-card:hover{border-color:var(--border2);}
.role-card.open{border-color:rgba(34,211,238,.25);box-shadow:0 0 20px rgba(34,211,238,.06);}

.rc-head{padding:16px 20px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;user-select:none;}
.role-card.open .rc-head{border-bottom:1px solid var(--border);}
.rch-r{display:flex;align-items:center;gap:12px;}
.role-num{
  width:30px;height:30px;
  background:linear-gradient(135deg,#0891B2,#0E7490);
  border-radius:7px;
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:13px;color:#fff;flex-shrink:0;
}
.rt{font-size:15px;font-weight:700;color:var(--t1);}
.rm{font-size:11px;color:var(--t2);margin-top:2px;letter-spacing:.2px;}
.rch-l{display:flex;align-items:center;gap:10px;}
.dept-tag{
  font-size:11px;font-weight:700;
  padding:3px 10px;border-radius:20px;
  background:var(--cyan-d);color:var(--cyan);
  border:1px solid rgba(34,211,238,.2);
  letter-spacing:.3px;
}
.chevron{color:var(--t3);font-size:11px;transition:transform .2s;display:inline-block;}
.role-card.open .chevron{transform:rotate(180deg);}
.rc-body{display:none;padding:20px;}
.role-card.open .rc-body{display:block;}

/* ─ Forms ─ */
.fg{display:flex;flex-direction:column;gap:5px;}
.fl{font-size:11px;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.5px;}
.fi{
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:7px;
  padding:9px 12px;
  font-size:13px;color:var(--t1);
  direction:rtl;width:100%;
  font-family:inherit;
  transition:border-color .2s,box-shadow .2s;
}
.fi:focus{outline:none;border-color:var(--cyan);box-shadow:0 0 0 2px rgba(34,211,238,.12);}
.fi::placeholder{color:var(--t3);}
textarea.fi{resize:vertical;min-height:100px;line-height:1.6;}
select.fi{cursor:pointer;}
option{background:var(--card);}
.fr4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:12px;margin-bottom:18px;}
.fr2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;}

/* ─ Candidate card ─ */
.cands-hdr{font-size:11px;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px;}
.cand-card{
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:9px;padding:16px;margin-bottom:12px;
  transition:border-color .2s;
}
.cand-card:hover{border-color:var(--border2);}
.cand-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.cand-num{font-size:11px;font-weight:700;color:var(--indigo);background:var(--purple-d);border:1px solid rgba(167,139,250,.2);padding:2px 9px;border-radius:20px;}
.btn-rm{background:none;border:none;color:var(--t3);cursor:pointer;font-size:16px;padding:2px 5px;border-radius:4px;transition:color .2s;}
.btn-rm:hover{color:var(--red);}

.cv-label-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:5px;}
.upload-lbl{
  font-size:11px;color:var(--cyan);cursor:pointer;font-weight:600;
  display:flex;align-items:center;gap:4px;
  padding:3px 8px;border-radius:5px;
  transition:background .15s;
  border:1px solid rgba(34,211,238,.2);
}
.upload-lbl:hover{background:var(--cyan-d);}

.btn-analyze{
  width:100%;
  background:linear-gradient(135deg,rgba(124,58,237,.8),rgba(109,40,217,.9));
  border:1px solid rgba(167,139,250,.3);
  color:#fff;padding:10px 16px;border-radius:8px;
  font-size:13px;font-weight:700;cursor:pointer;
  margin-top:10px;font-family:inherit;
  transition:all .2s;
  display:flex;align-items:center;justify-content:center;gap:8px;
  letter-spacing:.3px;
}
.btn-analyze:hover{box-shadow:0 0 20px rgba(167,139,250,.3);transform:translateY(-1px);}
.btn-analyze:disabled{opacity:.4;cursor:not-allowed;transform:none;}
.spinner{width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

/* ─ Analysis card ─ */
.analysis-card{
  background:var(--bg);
  border:1px solid rgba(167,139,250,.25);
  border-radius:8px;margin-top:12px;overflow:hidden;
}
.ac-top{
  background:linear-gradient(135deg,rgba(124,58,237,.15),rgba(109,40,217,.1));
  border-bottom:1px solid rgba(167,139,250,.15);
  padding:10px 14px;
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;
}
.ac-title{font-size:12px;font-weight:700;color:var(--purple);display:flex;align-items:center;gap:6px;letter-spacing:.3px;}
.ac-stats{display:flex;gap:8px;flex-wrap:wrap;}
.ac-stat{font-size:11px;color:var(--indigo);background:var(--purple-d);border:1px solid rgba(167,139,250,.2);padding:2px 9px;border-radius:20px;font-weight:600;}
.ac-body{padding:12px 14px;}
.ac-rl-row{display:flex;align-items:flex-start;gap:10px;margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid var(--border);}
.ac-rl-lbl{font-size:11px;color:var(--t2);font-weight:700;white-space:nowrap;padding-top:3px;letter-spacing:.3px;text-transform:uppercase;}
.ac-rl-pill{display:inline-block;padding:3px 12px;border-radius:20px;font-size:12px;font-weight:700;margin-bottom:5px;}
.ac-rl-exp{font-size:12px;color:var(--t2);line-height:1.5;}
.ac-cols{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.ac-col-t{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;}
.ac-col-t.s{color:var(--green);}
.ac-col-t.g{color:var(--red);}
.ac-list li{font-size:12px;color:var(--t2);margin-bottom:4px;padding-right:14px;position:relative;list-style:none;line-height:1.4;}
.ac-list.s li::before{content:'✓';position:absolute;right:0;color:var(--green);font-weight:700;}
.ac-list.g li::before{content:'·';position:absolute;right:0;color:var(--red);font-weight:700;}

.r-override{margin-top:12px;padding-top:12px;border-top:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.r-override .fl{white-space:nowrap;margin:0;}

.btn-add-cand{
  background:transparent;
  border:1px dashed var(--border2);
  color:var(--t2);
  padding:10px 16px;border-radius:8px;
  font-size:13px;font-weight:600;cursor:pointer;
  width:100%;transition:all .2s;font-family:inherit;
  margin-top:2px;
}
.btn-add-cand:hover{border-color:var(--cyan);color:var(--cyan);}
.btn-add-cand:disabled{opacity:.3;cursor:not-allowed;}

.role-footer{display:flex;align-items:center;justify-content:space-between;margin-top:18px;padding-top:16px;border-top:1px solid var(--border);flex-wrap:wrap;gap:10px;}
.btn-del{background:none;border:1px solid rgba(248,113,113,.2);color:var(--red);padding:7px 14px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit;}
.btn-del:hover{background:var(--red-d);}

.add-role-btn{
  background:transparent;
  border:1px dashed var(--border2);
  border-radius:12px;
  padding:20px;text-align:center;
  cursor:pointer;color:var(--t2);
  font-size:14px;font-weight:600;
  width:100%;transition:all .2s;font-family:inherit;
  margin-top:4px;
}
.add-role-btn:hover{border-color:var(--cyan);color:var(--cyan);background:var(--cyan-dd);}

/* ════════════ LOADING ════════════ */
#loading{
  display:none;position:fixed;inset:0;
  background:rgba(6,11,22,.85);
  backdrop-filter:blur(4px);
  z-index:999;
  align-items:center;justify-content:center;
}
#loading.show{display:flex!important;}
.loading-card{
  background:var(--card);
  border:1px solid rgba(34,211,238,.3);
  border-radius:14px;
  padding:40px 48px;
  text-align:center;
  box-shadow:var(--glow-c);
}
.loading-ring{
  width:52px;height:52px;
  border:3px solid var(--border2);
  border-top-color:var(--cyan);
  border-radius:50%;
  animation:spin .8s linear infinite;
  margin:0 auto 20px;
}
.loading-text{font-size:15px;font-weight:700;color:var(--cyan);letter-spacing:.5px;}
.loading-sub{font-size:12px;color:var(--t2);margin-top:6px;}

/* ════════════ DASHBOARD ════════════ */
#dashboard{background:var(--bg);}

.dash-head{
  background:var(--card);
  border-bottom:1px solid var(--border2);
  padding:28px 32px;
  position:relative;
  overflow:hidden;
}
.dash-head::before{
  content:'';position:absolute;bottom:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--cyan),transparent);
  opacity:.5;
}
.dash-head-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;}
.dh-brand{display:flex;align-items:center;gap:16px;}
.dh-icon{
  width:44px;height:44px;
  background:linear-gradient(135deg,#0891B2,#6D28D9);
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:20px;
  box-shadow:0 0 16px rgba(34,211,238,.3);
}
.dh-t{font-size:19px;font-weight:800;color:var(--t1);letter-spacing:-.3px;}
.dh-s{font-size:11px;color:var(--t2);letter-spacing:1px;text-
